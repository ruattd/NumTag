<Application x:Class="NumTag.App"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        RequestedThemeVariant="Default"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Application.Styles>
        <FluentTheme/>
    </Application.Styles>

    <TrayIcon.Icons><TrayIcons>
        <TrayIcon Icon="/Assets/logo.ico" ToolTipText="NumTag" Clicked="MenuItemVisibility_OnClicked">
            <TrayIcon.Menu>
                <NativeMenu>
                    <NativeMenuItem Header="显示/隐藏" Click="MenuItemVisibility_OnClicked"/>
                    <NativeMenuItem Header="设置" Click="MenuItemSettings_OnClick"/>
                    <NativeMenuItemSeparator/>
                    <NativeMenuItem Header="退出" Click="MenuItemExit_OnClick"/>
                </NativeMenu>
            </TrayIcon.Menu>
        </TrayIcon>
    </TrayIcons></TrayIcon.Icons>

</Application>
