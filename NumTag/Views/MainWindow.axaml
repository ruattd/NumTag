<controls:BaseWindow x:Class="NumTag.Views.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NumTag.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:NumTag.Controls"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.ico" Title="NumTag" Closing="Window_OnClosing"
        ShowInTaskbar="False" Topmost="True" WindowState="FullScreen"
        ShowActivated="True" WindowVisible="{Binding WindowVisible}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Background="{Binding Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" SharedSizeGroup="Hint"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto" SharedSizeGroup="Hint"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="1" Margin="20">
            <DockPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Margin="20" Text="{Binding Subtitle}" FontSize="{Binding SubtitleTextSize}" Foreground="{Binding Foreground}" DockPanel.Dock="Bottom" TextAlignment="Center"/>
                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="{Binding TitleTextSize}" Foreground="{Binding Foreground}" TextAlignment="Center"/>
            </DockPanel>
        </Grid>
        <TextBlock Grid.Row="2" Margin="10" Text="{Binding Hint}" FontSize="{Binding HintTextSize}" Foreground="{Binding HintForeground}" HorizontalAlignment="Center"/>
    </Grid>

</controls:BaseWindow>
