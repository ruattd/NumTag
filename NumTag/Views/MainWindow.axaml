<controls:BaseWindow x:Class="NumTag.Views.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NumTag.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:NumTag.Controls"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.ico" Title="NumTag"
        ShowInTaskbar="False" Topmost="True" WindowState="FullScreen"
        ShowActivated="True" WindowVisible="{Binding WindowVisible}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="Initialized">
            <vm:OnInitializedAction TargetObject="{Binding}"/>
        </EventTriggerBehavior>
    </Interaction.Behaviors>

    <Grid Background="{Binding Background}">
        <Interaction.Behaviors>
            <EventTriggerBehavior EventName="PointerPressed">
                <vm:OnClickBackgroundAction TargetObject="{Binding}"/>
            </EventTriggerBehavior>
        </Interaction.Behaviors>
        <Grid.RowDefinitions>
            <RowDefinition SharedSizeGroup="Hint"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto" SharedSizeGroup="Hint"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{Binding Subtitle}" FontSize="{Binding SubtitleTextSize}" Foreground="{Binding Foreground}" DockPanel.Dock="Bottom"/>
            <TextBlock Text="{Binding Title}" FontSize="{Binding TitleTextSize}" Foreground="{Binding Foreground}"/>
        </DockPanel>
        <TextBlock Grid.Row="2" Text="{Binding Hint}" FontSize="{Binding HintTextSize}" HorizontalAlignment="Center"/>
    </Grid>

</controls:BaseWindow>
